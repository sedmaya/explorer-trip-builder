# GOOGLE_GENAI_USE_VERTEXAI: Enable Vertex AI mode to use headless mode Google Auth (Application Default Credentials).
# Set to "true" to use IAM/Google Auth instead of Gemini API key.
GOOGLE_GENAI_USE_VERTEXAI="true"

# GOOGLE_CLOUD_PROJECT: Your Google Cloud Project ID (required for Vertex AI/Google Auth).
GOOGLE_CLOUD_PROJECT="YOUR_GOOGLE_CLOUD_PROJECT_ID"

# GOOGLE_CLOUD_LOCATION: Google Cloud Region/Location (e.g. us-central1).
GOOGLE_CLOUD_LOCATION="us-central1"

# GOOGLE_APPLICATION_CREDENTIALS: Path to your Google Cloud Service Account JSON key file.
# Required for headless mode authentication when running locally without gcloud CLI.
GOOGLE_APPLICATION_CREDENTIALS=""

# GEMINI_API_KEY: Required for Gemini AI Developer API calls when Vertex AI is disabled.
GEMINI_API_KEY=


# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_API_KEY: Required for the interactive map.
# Get one at: https://developers.google.com/maps/documentation/javascript/get-api-key
VITE_GOOGLE_MAPS_API_KEY=

